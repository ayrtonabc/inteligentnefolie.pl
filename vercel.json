
{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "^/panel/assets/(.*)$", "dest": "/panel/assets/$1" },
    { "src": "^/assets/(.*)$", "dest": "/assets/$1" },

    { "src": "^/panel(?:/.*)?$", "dest": "/panel/index.html" },

    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}
