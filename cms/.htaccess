SetEnv PHP_VER 5_3
SetEnv REGISTER_GLOBALS 0

Options -MultiViews
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.nieruchomoscwtajlandii\.pl$ [NC,OR]
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://nieruchomoscwtajlandii.pl%{REQUEST_URI} [R=301,L,NE]
RewriteBase /cms/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [QSA,L]
