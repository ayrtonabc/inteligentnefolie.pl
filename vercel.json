{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/panel/:path*", "destination": "/cms/index.html" },
    { "source": "/cms/:path*", "destination": "/cms/index.html" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
