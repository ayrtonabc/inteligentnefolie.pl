{
  "name": "seogrow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "cms",
    "sdk"
  ],
  "scripts": {
    "dev": "node scripts/dev-wrapper.mjs",
    "dev:debug": "cross-env NODE_OPTIONS='--inspect' next dev",
    "dev:inspect": "npm run dev:debug",
    "build:cms": "npm run build --prefix cms && node scripts/deploy-cms.mjs",
    "build": "npm run build:cms && next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "lucide-react": "^0.400.0",
    "next": "^15.0.0",
    "pocketbase": "^0.26.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-qr-code": "^2.2.0",
    "recharts": "^2.15.4",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^3.4.3",
    "typescript": "^5"
  }
}
