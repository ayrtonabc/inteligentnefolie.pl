# =====================================================
# Site Configuration
# =====================================================
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Tu Sitio
NEXT_PUBLIC_TENANT_ID=tu_tenant_id

# =====================================================
# PocketBase (CMS backend)
# =====================================================
NEXT_PUBLIC_POCKETBASE_URL=https://tu-pocketbase.example.com
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=tu_password_aqui
PB_API_TOKEN=tu_pb_api_token_aqui

# =====================================================
# Cache
# =====================================================
CMS_CACHE_TTL=3600

# =====================================================
# AI Providers (opcional)
# =====================================================
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=tu_api_key_aqui
AI_MODEL=deepseek-flash
RUFLO_PROVIDER=minimax
RUFLO_API_KEY=tu_api_key_aqui

# =====================================================
# TPAY Payments (opcional)
# =====================================================
TPAY_CLIENT_ID=tu_client_id
TPAY_SECRET_KEY=tu_secret_key
TPAY_API_URL=https://secure.tpay.com
