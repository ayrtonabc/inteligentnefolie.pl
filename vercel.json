{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "handle": "filesystem" },

    { "src": "^/panel$", "dest": "/cms/index.html" },
    { "src": "^/panel/(.*)", "dest": "/cms/index.html" },

    { "src": "^/cms$", "dest": "/cms/index.html" },
    { "src": "^/cms/(.*)", "dest": "/cms/index.html" },

    { "src": "^(.*)$", "dest": "/index.html" }
  ]
}
