{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/panel/:path*", "destination": "/cms/" },
    { "source": "/cms/:path*", "destination": "/cms/" },
    { "source": "/:path*", "destination": "/" }
  ]
}
